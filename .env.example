# Hayyan SOC Agent — Environment Template
# Copy this to .env and fill in your values
#
# LLM Fallback Chain (add as many as you have — agent uses all of them):
#   OpenRouter → Groq → Ollama (local) → Gemini
# At least one must be set. OpenRouter + Groq together = near-zero downtime.

# ── Primary: OpenRouter (openrouter.ai — $10 top-up → 1000 free req/day) ───
# Gives access to DeepSeek v3, Qwen3-235B, Llama 3.3 70B, and 300+ models.
# After $10 top-up: 20 req/min, 1000 req/day on free models.
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# ── Fallback 1: Groq (console.groq.com — 14,400 free req/day) ──────────────
GROQ_API_KEY=your_groq_api_key_here
MODEL_NAME=llama-3.3-70b-versatile

# ── Fallback 2: Ollama local (ollama.com — free, works offline) ─────────────
# Install: https://ollama.com  |  Pull model: ollama pull qwen3:4b
# Ollama is always tried — no key needed, just needs Ollama running locally.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# ── Fallback 3: Google Gemini (aistudio.google.com — free tier) ─────────────
GOOGLE_API_KEY=AIza-your-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── Splunk REST API ──────────────────────────────────────────────────────────
# NOTE: In this lab, Docker maps host:8088 → container:8089 (REST API)
#       host:8089 → container:8000 (Web UI). Adjust per your docker run flags.
SPLUNK_HOST=localhost
SPLUNK_PORT=8088
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=your_splunk_password_here
SPLUNK_SCHEME=https
SPLUNK_VERIFY_SSL=false

# ── Splunk HEC (HTTP Event Collector) ────────────────────────────────────────
# Create a token: Splunk UI → Settings → Data Inputs → HTTP Event Collector
# Then create index "vuln_scans" and "ai_soc_audit" via Settings → Indexes
SPLUNK_HEC_TOKEN=your_hec_token_here
SPLUNK_HEC_URL=https://localhost:8088

# ── MISP Threat Intelligence Platform ────────────────────────────────────────
# Deploy MISP: docker compose -f docker-compose.misp.yml up -d
# Get API key: MISP UI (https://localhost:8443) → Administration → Auth Keys
# Create a dedicated read/write user "splunk_reader" for the API key (not admin)
MISP_URL=https://localhost:8443
MISP_API_KEY=your_misp_api_key_here
MISP_VERIFY_SSL=false
# Minimum CVSS score to create MISP events from vulnerability scan findings
MISP_VULN_MIN_CVSS=7.0

# ── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8500

# ── Rocky Linux Scanner Node ─────────────────────────────────────────────────
# Used by normalization scripts to label scan events with the authorized source IP
ROCKY_IP=192.168.56.20

# ── Optional: LangSmith tracing ─────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=hayyan-ai-soc
