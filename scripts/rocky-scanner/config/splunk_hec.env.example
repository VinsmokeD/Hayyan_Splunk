# Hayyan SOC Scanner — Credentials
# Copy to: /opt/hayyan-scan/config/splunk_hec.env
# Permissions: chmod 600 /opt/hayyan-scan/config/splunk_hec.env
# Owner: root (scanner runs as root via systemd)

# Splunk HEC — create token at: Splunk UI → Settings → Data Inputs → HTTP Event Collector
SPLUNK_HEC_TOKEN=your-hec-token-here
SPLUNK_HEC_URL=https://192.168.56.1:8088
SPLUNK_HEC_INDEX=vuln_scans

# MISP — create API key at: MISP UI → Administration → Auth Keys
# Use a dedicated user "scanner_writer" with only event create permissions
MISP_URL=https://192.168.56.1:8443
MISP_API_KEY=your-misp-api-key-here
MISP_MIN_CVSS=7.0
